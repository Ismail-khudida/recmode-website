# --- Supabase ---
# Aus dem Supabase-Projekt: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Name des Storage-Buckets für hochgeladene Dokumente.
SUPABASE_STORAGE_BUCKET=documents

# --- App ---
# Eigene App-Domain für den CSRF-Schutz (/api/upload akzeptiert nur Requests
# von dieser Origin) sowie für E-Mail-Redirect-Links. Lokal: http://localhost:3000
APP_ORIGIN=http://localhost:3000

# --- Rate-Limiting / Kostenkontrolle ---
# Maximale Analysen pro Nutzer und pro Tag.
DAILY_USER_ANALYSIS_LIMIT=10
# Globale Obergrenze aller Analysen pro Tag.
DAILY_GLOBAL_ANALYSIS_LIMIT=200

# --- KI-Analyse (Anthropic) ---
# https://console.anthropic.com/ -> API Keys
ANTHROPIC_API_KEY=sk-ant-...
# Optional: Modell überschreiben (Standard: claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8
