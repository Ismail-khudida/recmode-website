# --- Supabase ---
# Aus dem Supabase-Projekt: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-Role-Key wird serverseitig u.a. für Storage-Uploads genutzt.
# NIEMALS im Client verwenden oder veröffentlichen.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Name des Storage-Buckets für hochgeladene Dokumente.
SUPABASE_STORAGE_BUCKET=documents

# --- KI-Analyse (Anthropic) ---
# https://console.anthropic.com/ -> API Keys
ANTHROPIC_API_KEY=sk-ant-...
# Optional: Modell überschreiben (Standard: claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8
